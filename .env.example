# LuxoraAI Backend Environment Variables Example

# Application Settings
PROJECT_NAME="LuxoraAI"

# Database Configuration (PostgreSQL)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/luxoraai"

# OpenRouter API (for Google Gemma 4 31B Free)
# Get your key from: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY="your_openrouter_api_key"

# --- Phase 2 Variables (Placeholders for future implementation) ---
JWT_SECRET_KEY="your_jwt_secret_key"
# STRIPE_SECRET_KEY="your_stripe_secret_key"
